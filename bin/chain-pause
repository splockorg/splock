#!/usr/bin/env bash
# bin/chain-pause — operator entry point to pause the live overnight chain (CCOR.1 T-5).
#
# Per implplan §T-5 + design_resolutions R-cli-arg-shape +
# R-cli-lint-conformance. Thin POSIX wrapper around
# `bin/_chain_pause/main.py`. Activates the project venv if available so
# operator invocations from outside PyCharm have the right interpreter.
#
# Usage:
#   bin/chain-pause --slug <slug> [--reason "text"] [--chain-id <id>]
#
# Exit codes (per bin/_chain_overnight/exit_codes.py):
#   0  = success (pause sentinel acquired)
#   2  = driver crash (plan-dir missing, no running lock, dead PID, etc.)
#   23 = already paused (pause sentinel already held)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

# Activate venv if present and not already active (idempotent).
VENV="${SPLOCK_VENV:-.venv}/bin/activate"
if [ -z "${VIRTUAL_ENV:-}" ] && [ -f "$VENV" ]; then
  # shellcheck disable=SC1090
  source "$VENV"
fi

exec "$(command -v python || command -v python3)" -m bin._chain_pause.main "$@"
