#!/usr/bin/env bash
# bin/eval-baseline — mint or list baselines (§J.impl.7).
#
# Usage:
#   bin/eval-baseline <slug> --mint <name> [--notes <text>]
#   bin/eval-baseline <slug> --list
#
# Exit codes: 0 ok / 1 usage / 5 unsupported-schema / 7 atomic-write /
#             33 baseline-missing / 34 dataset-empty.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# Preserve the invoking directory for bin/_env_paths.project_root():
# the cd below moves to the plugin/checkout root, which in installed-
# plugin mode is NOT the adopter repo the CLI must operate on.
export SPLOCK_CALLER_PWD="${SPLOCK_CALLER_PWD:-$PWD}"
cd "$REPO_ROOT"

VENV_PATH="${SPLOCK_VENV:-.venv}"
if [ -f "$VENV_PATH/bin/activate" ] && [ -z "${VIRTUAL_ENV:-}" ]; then
    # shellcheck disable=SC1091
    source "$VENV_PATH/bin/activate"
fi

exec "$(command -v python || command -v python3)" -m bin._eval_baseline.main "$@"
