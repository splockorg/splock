#!/usr/bin/env bash
# bin/plan — operator-direct planner CLI (Call 1 reasoning + Call 2 emission).
#
# Per implplan §D.impl.2. Thin POSIX wrapper around
# `bin/_planner/main.py plan`. Activates the project venv if available
# so operator invocations from outside PyCharm have the right interpreter.
#
# Usage:
#   bin/plan <slug> [--tier=...] [--repo-state=...] [--chain-id=...]
#
# Exit codes per implplan §A.impl.3a (closed-enum shared registry):
#   0  = success
#   1  = usage error
#   7  = atomic write failed
#   16 = SDK retry exhausted (error_max_structured_output_retries)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# Preserve the invoking directory for bin/_env_paths.project_root():
# the cd below moves to the plugin/checkout root, which in installed-
# plugin mode is NOT the adopter repo the CLI must operate on.
export SPLOCK_CALLER_PWD="${SPLOCK_CALLER_PWD:-$PWD}"
cd "$REPO_ROOT"

# Activate venv if present and not already active (idempotent).
VENV="${SPLOCK_VENV:-.venv}/bin/activate"
if [ -z "${VIRTUAL_ENV:-}" ] && [ -f "$VENV" ]; then
  # shellcheck disable=SC1090
  source "$VENV"
fi

# Informational banner (stderr): the planner bills the Claude Code
# subscription via the claude_agent_sdk transport (bin/_sdk_bridge.py); it
# does NOT read ANTHROPIC_API_KEY. A missing key is expected, not an error —
# do not refuse to run on its account. See commands/plan.md "Auth & billing".
echo "splock: planner uses the Claude Code subscription transport (no ANTHROPIC_API_KEY required)" >&2

exec "$(command -v python || command -v python3)" -m bin._planner.main plan "$@"
