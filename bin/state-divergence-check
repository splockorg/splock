#!/usr/bin/env bash
# POSIX shell wrapper for `bin/state-divergence-check` (Python under
# bin/_state_divergence/). Per implplan §C.impl.4.
#
# Run from project root so module imports resolve.

set -eu

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Preserve the invoking directory for bin/_env_paths.project_root():
# the cd below moves to the plugin/checkout root, which in installed-
# plugin mode is NOT the adopter repo whose state we replay.
export SPLOCK_CALLER_PWD="${SPLOCK_CALLER_PWD:-$PWD}"
cd "$REPO_ROOT"

VENV_PY="${SPLOCK_VENV:-.venv}/bin/python"
if [ -x "${VENV_PY}" ]; then
    PY="${VENV_PY}"
else
    PY="$(command -v python3 || command -v python)"
fi

exec "${PY}" -m bin._state_divergence.main "$@"
