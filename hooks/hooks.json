{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Read|Bash|Task",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/security-dispatch.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/intent-on-first-edit.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/lazy-dump-cap.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/chain-suppression-block.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/eval-gate-pre-commit.sh" }
        ]
      },
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/chain-sealed-state-delete-block.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/test-at-edit.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/chain-test-file-edit-flag.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/bin/plan-render-on-edit.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/splock-session-start.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/verify-on-stop.sh" }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/splock-stop.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/splock-user-prompt-submit.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/splock-subagent-stop.sh" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/splock-session-end.sh" }
        ]
      }
    ]
  }
}
