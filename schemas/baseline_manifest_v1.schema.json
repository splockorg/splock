{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/splockorg/splock/blob/main/schemas/baseline_manifest_v1.schema.json",
  "title": "Baseline manifest",
  "description": "Schema for docs/plans/<slug>/_baseline/<system-version>/manifest.json. Per splock implplan §J.impl.7. Baselines are sealed-state; only bin/eval-baseline writes here.",
  "type": "object",
  "required": [
    "schema_version",
    "baseline_name",
    "minted_at",
    "minted_by",
    "commit_sha",
    "case_ids",
    "system_config_refs",
    "notes_path"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "baseline_name": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}_[a-zA-Z0-9_-]+$"},
    "minted_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?Z$"},
    "minted_by": {"type": "string", "const": "bin/eval-baseline:mint"},
    "commit_sha": {"type": "string", "minLength": 1},
    "case_ids": {"type": "array", "items": {"type": "string"}},
    "system_config_refs": {"type": "object"},
    "notes_path": {"type": "string", "const": "notes.md"}
  }
}
